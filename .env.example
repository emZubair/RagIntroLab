# RagIntroLab — environment configuration
# Copy this file to ".env" and fill in values to switch the GENERATION backend.
#   cp .env.example .env
#
# If you leave everything unset (or LLM_PROVIDER=ollama), generation uses the
# local gemma4 model via Ollama and NO API key is needed. Embeddings always run
# locally regardless of these settings.

# Which generation backend: ollama (default) | anthropic | openai
LLM_PROVIDER=ollama

# Remote model name (only used when LLM_PROVIDER is anthropic or openai).
# Defaults if left blank:  anthropic -> claude-opus-4-8   openai -> gpt-4o
# LLM_MODEL=claude-opus-4-8

# Remote provider API key (required for anthropic/openai; leave blank for local).
# If this is empty, generation falls back to the local model even if a provider
# is named above.
# LLM_API_KEY=

# --- Local (Ollama) overrides — usually leave as-is ---
# OLLAMA_BASE_URL=http://localhost:11434   # in production this points at the Ollama accessory
# LOCAL_MODEL=gemma4
# EMBED_MODEL=nomic-embed-text

# --- Cost / abuse controls (matter mainly for a public deployment) ---
# MAX_OUTPUT_TOKENS=512        # cap the answer length -> caps remote output-token spend
# RATE_LIMIT=240 per hour      # per-IP limit on the web UI's /api/ask (tighten in prod, e.g. "10 per hour")
