# Copy to ".kamal/secrets" (gitignored) for LOCAL kamal commands.
# In CI (GitHub Actions) these are injected from GitHub Secrets instead.
#
# Kamal reads these names; values come from the environment.

# OpenAI API key — the app reads it as LLM_API_KEY.
LLM_API_KEY=$LLM_API_KEY

# Registry password for pushing/pulling the image on GHCR.
# Locally: a GitHub Personal Access Token with read:packages/write:packages.
# In CI:   the built-in GITHUB_TOKEN.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
